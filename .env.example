# ============================================
# POS HULIO - Konfigurasi Bengkel / Retail
# ============================================
# Salin file ini menjadi .env.local lalu isi sesuai kebutuhan.
# Untuk penggunaan lokal (tanpa cloud), cukup isi bagian AI saja.

# --- AI (Opsional) ---
# Untuk fitur AI Consultant. Daftar gratis di https://openrouter.ai/settings/keys
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openrouter/auto

# --- Cloud Sync (Opsional) ---
# Isi jika ingin data tersinkron antar perangkat (misal: kasir + komputer belakang)
# Bisa pakai Supabase (gratis) atau Upstash Redis
VITE_CLOUD_ENABLED=false
VITE_STORE_ID=bengkel_saya
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=erp-media

# --- Pengaturan Lanjutan ---
# Set false jika tidak ingin user mengubah konfigurasi dari UI
VITE_ALLOW_RUNTIME_SETTINGS=true
